<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hacker.code.infrastructure.mapper.FundMapper">

    <sql id="fundConditionSql">
        FROM fund f
        <where>
            <if test="keyword != null and keyword != ''">
                AND (f.fund_code LIKE CONCAT('%', #{keyword}, '%')
                OR f.fund_name LIKE CONCAT('%', #{keyword}, '%'))
            </if>
            <if test="fundTypes != null and fundTypes.size() > 0">
                AND f.fund_type IN
                <foreach collection="fundTypes" item="type" open="(" separator="," close=")">
                    #{type}
                </foreach>
            </if>
            <if test="status != null">
                AND f.status = #{status}
            </if>
        </where>
    </sql>

    <select id="selectByCondition" resultType="com.hacker.code.infrastructure.persistence.po.FundPO">
        SELECT f.*
        <include refid="fundConditionSql"/>
        ORDER BY f.fund_code
    </select>

    <select id="selectByConditionPage" resultType="com.hacker.code.infrastructure.persistence.po.FundPO">
        SELECT f.*
        <include refid="fundConditionSql"/>
        ORDER BY f.fund_code
    </select>

</mapper>
